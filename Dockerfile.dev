# Dockerfile for Frontend Development
FROM node:20-slim

WORKDIR /app

# Copy package files first for better caching
COPY package*.json ./
RUN npm install

# Copy the rest of the code
COPY . .

# Expose Vite's port from config
EXPOSE 3000

# Start Vite in dev mode with host binding
CMD ["npm", "run", "dev", "--", "--host"]
